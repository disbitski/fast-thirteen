# Browser-publishable Supabase values only.
# Leave blank to keep auth disabled and local-only tracking active.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Keep false until migration writes are explicitly reviewed and enabled.
SUPABASE_MIGRATION_WRITES_ENABLED=false
SUPABASE_MIGRATION_CONFIRMATIONS_ENABLED=false
SUPABASE_MIGRATION_FINALIZATION_ENABLED=false

# Optional local development values. Do not commit real secrets.
SUPABASE_PROJECT_ID=

# Never commit service-role keys, JWT secrets, or Apple private keys.
